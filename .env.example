# Email subject used in Gmail search query.
ASSUNTO=Relatorio Financeiro Mensal

# Base spreadsheet path (relative to project root).
BASE_SPREADSHEET_PATH=core/base.xlsx

# Downloaded attachments directory.
DOWNLOADS_DIR=downloads

# Processed email ids control file.
PROCESSED_IDS_FILE=processed_ids.txt

# Keep downloaded files after processing.
KEEP_DOWNLOADS=true

# Optional OAuth credentials path (absolute or relative to project root).
# If empty, defaults to "credentials.json". Also accepts fallback file
# pattern "client_secret*.json" in project root.
GOOGLE_CREDENTIALS_PATH=credentials.json

# Optional OAuth token path (absolute or relative to project root).
GOOGLE_TOKEN_PATH=token.json
